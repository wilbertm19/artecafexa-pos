# Archivo .gitignore para el proyecto ArteCafexa

# ===========================
# Backend (Python/FastAPI)
# ===========================

# Credenciales de Google (NUNCA subir)
backend/credentials.json
backend/*.json
!backend/package.json

# Variables de entorno
backend/.env
backend/.env.local
backend/.env.*.local

# Python
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.so
backend/.Python
backend/env/
backend/venv/
backend/ENV/
backend/env.bak/
backend/venv.bak/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/dist/
backend/build/
backend/*.egg-info/

# ===========================
# Frontend (Next.js)
# ===========================

# Variables de entorno
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Next.js
frontend/.next/
frontend/out/
frontend/build/
frontend/.cache/

# Node modules
frontend/node_modules/

# Testing
frontend/coverage/
frontend/.nyc_output/

# Misc
frontend/.DS_Store
frontend/*.pem

# Debug
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Vercel
frontend/.vercel

# TypeScript
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ===========================
# IDEs y Editores
# ===========================

# VSCode
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ===========================
# Sistema Operativo
# ===========================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ===========================
# Otros
# ===========================

# Logs
*.log
logs/

# Temporales
*.tmp
*.temp
*.swp
*.swo
*.bak
